generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../../prisma/dev.db"
}

// ==================== AUTH & STORE ====================

model Store {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  address   String?
  phone     String?
  logo      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  zones      Zone[]
  categories Category[]
  products   Product[]
  orders     Order[]
  customers  Customer[]
  tags       Tag[]
  configs    StoreConfig[]
}

model StoreConfig {
  id      String @id @default(cuid())
  storeId String
  store   Store  @relation(fields: [storeId], references: [id])
  key     String
  value   String

  @@unique([storeId, key])
}

model User {
  id           String   @id @default(cuid())
  storeId      String?
  store        Store?   @relation(fields: [storeId], references: [id])
  name         String
  email        String?  @unique
  phone        String?
  passwordHash String
  role         String   @default("CASHIER")
  avatar       String?
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[] @relation("CashierOrders")

  @@unique([storeId, email])
}

model Tag {
  id        String   @id @default(cuid())
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id])
  name      String
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())

  @@unique([storeId, name])
}

// ==================== CUSTOMER ====================

model Customer {
  id          String    @id @default(cuid())
  storeId     String?
  store       Store?    @relation(fields: [storeId], references: [id])
  name        String?
  phone       String?
  avatar      String?
  points      Int       @default(0)
  balance     Float     @default(0)
  totalSpent  Float     @default(0)
  visitCount  Int       @default(0)
  stamps      Int       @default(0)
  lastVisitAt DateTime?
  tier         String    @default("REGULAR")
  referralCode    String?   @unique
  referredBy      String?
  isDistributor   Boolean   @default(false)
  commissionRate  Float     @default(5)
  totalCommission Float     @default(0)
  tags            String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  orders    Order[]
  credits   Credit[]
  addresses DeliveryAddress[]
  coupons   Coupon[]
  checkIns  CheckIn[]

  @@unique([storeId, phone])
}

model DeliveryAddress {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  label      String   @default("")
  address    String
  contactName String  @default("")
  phone      String   @default("")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// ==================== PRODUCT & MENU ====================

model Category {
  id        String    @id @default(cuid())
  storeId   String
  store     Store     @relation(fields: [storeId], references: [id])
  name      String
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  parentId  String?
  parent    Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([storeId, name])
}

model Product {
  id          String     @id @default(cuid())
  storeId     String
  store       Store      @relation(fields: [storeId], references: [id])
  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id])
  name        String
  description String?
  image       String?
  price       Float
  costPrice   Float?
  discountPrice Float?
  discountEnd   DateTime?
  unit        String     @default("份")
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  barcode     String?
  stock       Int        @default(0)
  lowStockAt  Int        @default(10)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  specs      Spec[]
  orderItems OrderItem[]
}

model Spec {
  id         String       @id @default(cuid())
  productId  String
  product    Product      @relation(fields: [productId], references: [id])
  name       String
  type       String       @default("SELECT")
  isRequired Boolean      @default(false)
  sortOrder  Int          @default(0)
  options    SpecOption[]
}

model SpecOption {
  id        String  @id @default(cuid())
  specId    String
  spec      Spec    @relation(fields: [specId], references: [id])
  label     String
  priceAdj  Float   @default(0)
  sortOrder Int     @default(0)
}

// ==================== TABLE MANAGEMENT ====================

model Zone {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  tables Table[]
}

model Table {
  id        String   @id @default(cuid())
  zoneId    String
  zone      Zone     @relation(fields: [zoneId], references: [id])
  label     String
  capacity  Int      @default(4)
  status    String   @default("AVAILABLE")
  qrCodeUrl String?
  sortOrder Int      @default(0)
  posX      Int?
  posY      Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[] @relation("TableOrders")

  @@unique([zoneId, label])
}

// ==================== DEVICES & PRINTING ====================

model Device {
  id         String   @id @default(cuid())
  storeId    String
  name       String
  type       String   @default("PRINTER_THERMAL")
  connection String   @default("NETWORK")
  ip         String?
  port       Int?
  isActive   Boolean  @default(true)
  status     String   @default("online")
  jobs       PrintJob[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PrintJob {
  id         String   @id @default(cuid())
  deviceId   String?
  device     Device?  @relation(fields: [deviceId], references: [id])
  orderId    String?
  type       String   @default("ORDER_TICKET")
  content    String?
  status     String   @default("PENDING")
  retryCount Int      @default(0)
  errorMsg   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ==================== ORDER & PAYMENT ====================

model Order {
  id            String    @id @default(cuid())
  storeId       String
  store         Store     @relation(fields: [storeId], references: [id])
  orderNo       String    @unique
  type          String    @default("DINE_IN")
  status        String    @default("PENDING")
  tableId       String?
  table         Table?    @relation("TableOrders", fields: [tableId], references: [id])
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  cashierId     String?
  cashier       User?     @relation("CashierOrders", fields: [cashierId], references: [id])
  items         OrderItem[]
  payments      Payment[]
  discounts     Discount[]
  credits       Credit[]
  subtotal      Float
  discountTotal Float     @default(0)
  total         Float
  paidAmount    Float     @default(0)
  changeAmount  Float     @default(0)
  isPaid        Boolean   @default(false)
  isClosed      Boolean   @default(false)
  guestCount    Int       @default(1)
  note          String?
  rating        Int?
  closedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id])
  productId    String
  product      Product @relation(fields: [productId], references: [id])
  productName  String
  quantity     Int     @default(1)
  unitPrice    Float
  specSnapshot String?
  subtotal     Float
  status       String  @default("PENDING")
  note         String?
  sortOrder    Int     @default(0)
}

model Discount {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  type      String
  name      String
  amount    Float
  ruleId    String?
  createdBy String
  createdAt DateTime @default(now())
}

model Payment {
  id          String    @id @default(cuid())
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id])
  method      String
  amount      Float
  status      String    @default("PENDING")
  gatewayRef  String?
  paidAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ==================== CREDIT ====================

model Credit {
  id         String    @id @default(cuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id])
  orderId    String?
  order      Order?    @relation(fields: [orderId], references: [id])
  type       String
  amount     Float
  balance    Float
  note       String?
  dueDate    DateTime?
  settledAt  DateTime?
  createdAt  DateTime  @default(now())
}

// ==================== AUDIT ====================

model AuditLog {
  id        String   @id @default(cuid())
  storeId   String
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  ip        String?
  createdAt DateTime @default(now())
}

// ==================== CAMPAIGN & COUPON ====================

model Campaign {
  id        String       @id @default(cuid())
  storeId   String
  name      String
  type      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean      @default(true)
  rules     String?
  createdAt DateTime     @default(now())
  coupons   Coupon[]
}

model Coupon {
  id         String         @id @default(cuid())
  storeId    String
  campaignId String?
  campaign   Campaign?      @relation(fields: [campaignId], references: [id])
  customerId String?
  customer   Customer?      @relation(fields: [customerId], references: [id])
  code       String         @unique
  type       String
  value      Float
  minSpend   Float          @default(0)
  startDate  DateTime
  endDate    DateTime
  usageLimit Int            @default(1)
  usedCount  Int            @default(0)
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  usages     CouponUsage[]
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id])
  orderId   String?
  orderNo   String?
  amount    Float
  createdAt DateTime @default(now())
}

// ==================== PROCUREMENT ====================

model Procurement {
  id        String             @id @default(cuid())
  storeId   String
  supplier  String?
  status    String             @default("PENDING")
  totalCost Float
  note      String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  items     ProcurementItem[]
}

model ProcurementItem {
  id            String      @id @default(cuid())
  procurementId String
  procurement   Procurement @relation(fields: [procurementId], references: [id])
  productId     String?
  productName   String
  quantity      Int
  unitCost      Float
}

model CheckIn {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  date       String
  points     Int      @default(1)
  createdAt  DateTime @default(now())

  @@unique([customerId, date])
}

model GiftCode {
  id         String    @id @default(cuid())
  storeId    String
  code       String    @unique
  amount     Float
  isUsed     Boolean   @default(false)
  usedBy     String?
  usedAt     DateTime?
  createdAt  DateTime  @default(now())
}

model GroupBuy {
  id          String         @id @default(cuid())
  storeId     String
  productId   String
  productName String
  price       Float          @default(0)
  origPrice   Float          @default(0)
  minPeople   Int            @default(2)
  status      String         @default("ACTIVE")
  expiresAt   DateTime       @default(now())
  createdAt   DateTime       @default(now())
  members     GroupBuyMember[]
}

model GroupBuyMember {
  id        String   @id @default(cuid())
  groupId   String
  group     GroupBuy @relation(fields: [groupId], references: [id])
  customerId String
  createdAt DateTime @default(now())

  @@unique([groupId, customerId])
}

model Commission {
  id           String   @id @default(cuid())
  customerId   String
  orderId      String?
  orderAmount  Float
  rate         Float
  amount       Float
  createdAt    DateTime @default(now())
}

model Reservation {
  id         String   @id @default(cuid())
  storeId    String
  customerId String?
  tableId    String?
  tableLabel String
  name       String
  phone      String
  date       String
  timeSlot   String
  guests     Int      @default(2)
  status     String   @default("PENDING")
  note       String?
  createdAt  DateTime @default(now())
}
