# === Required ===
AUTH_SECRET=change-me-to-random-32-chars
AUTH_URL=https://your-domain.com

# === Database ===
# SQLite (dev): file:../../packages/prisma/dev.db
# PostgreSQL (prod): postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://pos:pos_secret@localhost:5432/restaurant_pos

# === WeChat Mini-Program ===
WECHAT_APPID=wx_your_appid
WECHAT_SECRET=your_app_secret

# === WeChat Pay (set both to enable production) ===
WECHAT_MCHID=
WECHAT_API_V3_KEY=
WECHAT_CERT_PATH=/path/to/apiclient_cert.pem
WECHAT_KEY_PATH=/path/to/apiclient_key.pem

# === Optional ===
# NODE_ENV=production
# PORT=3000
