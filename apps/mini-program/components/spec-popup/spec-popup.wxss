.mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 200; display: flex; align-items: flex-end; }
.panel { width: 100%; background: #fff; border-radius: 32rpx 32rpx 0 0; padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); max-height: 80vh; overflow-y: auto; }
.img-area { width: 100%; height: 300rpx; background: #f0f5ff; display: flex; align-items: center; justify-content: center; }
.img-text { font-size: 80rpx; color: #2563eb; font-weight: bold; }
.info-top { padding: 24rpx 32rpx 0; }
.p-name { font-size: 34rpx; font-weight: bold; }
.prices { display: flex; align-items: baseline; gap: 12rpx; margin-top: 8rpx; }
.p-price { font-size: 36rpx; font-weight: bold; color: #ef4444; }
.p-orig { font-size: 26rpx; color: #999; text-decoration: line-through; }
.p-unit { font-size: 24rpx; margin-top: 4rpx; display: block; }
.spec-group { padding: 16rpx 32rpx 0; }
.spec-label { font-size: 26rpx; color: #999; margin-bottom: 8rpx; display: block; }
.spec-options { display: flex; flex-wrap: wrap; gap: 12rpx; }
.spec-option { padding: 10rpx 24rpx; background: #f5f5f5; border-radius: 8rpx; font-size: 26rpx; border: 2rpx solid transparent; }
.spec-option.active { background: #eff6ff; border-color: #2563eb; color: #2563eb; }
.bottom-bar { display: flex; align-items: center; padding: 24rpx 32rpx; gap: 20rpx; }
.qty-ctrl { display: flex; align-items: center; gap: 8rpx; }
.qty-btn { width: 48rpx; height: 48rpx; border-radius: 50%; border: 2rpx solid #ddd; display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: #666; }
.qty-btn.add { background: #2563eb; color: #fff; border-color: #2563eb; }
.qty-num { font-size: 30rpx; min-width: 48rpx; text-align: center; }
