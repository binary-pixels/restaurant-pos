.spec-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 200;
  display: flex; align-items: flex-end;
}
.spec-panel {
  width: 100%; background: #fff; border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  max-height: 70vh; overflow-y: auto;
}
.spec-name { font-size: 34rpx; font-weight: bold; margin-bottom: 32rpx; display: block; }
.spec-group { margin-bottom: 28rpx; }
.spec-label { font-size: 26rpx; color: #999; margin-bottom: 12rpx; display: block; }
.spec-options { display: flex; flex-wrap: wrap; gap: 16rpx; }
.spec-option {
  padding: 12rpx 28rpx; background: #f5f5f5; border-radius: 8rpx;
  font-size: 26rpx; border: 2rpx solid transparent;
}
.spec-option.active { background: #eff6ff; border-color: #2563eb; color: #2563eb; }
.spec-actions { display: flex; gap: 20rpx; margin-top: 36rpx; }
.spec-actions .btn { flex: 1; }
