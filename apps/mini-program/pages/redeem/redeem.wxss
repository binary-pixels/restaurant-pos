.page { min-height: 100vh; background: #f5f5f5; padding: 40rpx; }
.card { background: #fff; border-radius: 24rpx; padding: 48rpx 32rpx; text-align: center; }
.title { font-size: 36rpx; font-weight: bold; display: block; }
.desc { font-size: 28rpx; color: #999; margin: 8rpx 0 32rpx; display: block; }
.result { margin-top: 24rpx; text-align: center; font-size: 30rpx; color: #16a34a; font-weight: bold; }
