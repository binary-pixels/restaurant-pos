.page { min-height: 100vh; background: linear-gradient(135deg, #fef3c7, #fde68a); display: flex; flex-direction: column; align-items: center; padding-top: 60rpx; }
.header { text-align: center; margin-bottom: 48rpx; }
.title { font-size: 44rpx; font-weight: bold; color: #92400e; }
.desc { font-size: 28rpx; color: #a16207; display: block; margin-top: 8rpx; }

.card-container { position: relative; width: 560rpx; height: 360rpx; }
.card { width: 100%; height: 100%; background: linear-gradient(135deg, #2563eb, #1e40af); border-radius: 24rpx; display: flex; align-items: center; justify-content: center; }
.card-hint { color: #93c5fd; font-size: 28rpx; }
.scratch-canvas { position: absolute; top: 0; left: 0; width: 560rpx; height: 360rpx; border-radius: 24rpx; }
.result-card { width: 100%; height: 100%; background: #fff; border-radius: 24rpx; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.result-icon { font-size: 72rpx; }
.result-text { font-size: 36rpx; font-weight: bold; color: #333; margin-top: 8rpx; }
