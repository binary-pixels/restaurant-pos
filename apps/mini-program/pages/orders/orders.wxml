<view class="container">
  <view class="tabs flex">
    <view class="tab {{activeTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">全部</view>
    <view class="tab {{activeTab === 'active' ? 'active' : ''}}" bindtap="switchTab" data-tab="active">进行中</view>
  </view>

  <view class="spinner-wrap" wx:if="{{loading}}"><view class="spinner"></view><text class="spinner-text">加载中</text></view>

  <view class="order-card card" wx:for="{{orders}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
    <view class="flex-between mb-2">
      <text class="text-sm text-gray">#{{item.orderNo}}</text>
      <text class="badge {{item.isPaid ? 'badge-green' : 'badge-red'}}">{{item.isPaid ? '已付' : '未付'}}</text>
    </view>
    <view class="flex-between mb-2">
      <text class="font-bold text-lg">{{item.typeLabel}} {{item.tableLabel || ''}}</text>
      <text class="badge {{item.status === 'COMPLETED' ? 'badge-green' : item.status === 'CANCELLED' ? 'badge-gray' : 'badge-blue'}}">{{statusMap[item.status] || item.status}}</text>
    </view>
    <view class="flex-between">
      <text>{{item.itemCount}} 道菜</text>
      <text class="price">¥{{item.total}}</text>
    </view>
    <view class="flex-between mt-1">
      <text class="text-sm text-gray">{{item.timeStr}}</text>
      <text wx:if="{{item.rating}}" style="color:#f59e0b">
        <text wx:for="{{[1,2,3,4,5]}}" wx:key="*this">{{item <= item.rating ? '★' : '☆'}}</text>
      </text>
    </view>
  </view>

  <view class="empty" wx:if="{{!loading && orders.length === 0}}">
    <text class="empty-icon">📋</text>
    <text class="empty-text">暂无订单</text>
  </view>
</view>
