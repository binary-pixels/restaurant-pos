.page { min-height: 100vh; background: #f5f5f5; }
.header-card { background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff; padding: 48rpx 32rpx; text-align: center; }
.header-title { font-size: 34rpx; font-weight: bold; }
.header-balance { font-size: 28rpx; margin-top: 8rpx; opacity: 0.85; display: block; }
.section-label { font-size: 28rpx; color: #666; padding: 24rpx 24rpx 12rpx; display: block; }
.amount-grid { display: flex; flex-wrap: wrap; padding: 0 24rpx; gap: 16rpx; }
.amount-item { width: calc(33.33% - 12rpx); background: #fff; border-radius: 12rpx; padding: 28rpx 0; text-align: center; font-size: 32rpx; font-weight: bold; color: #333; border: 2rpx solid #e5e7eb; }
.amount-item.active { border-color: #2563eb; color: #2563eb; background: #eff6ff; }
.custom-amount { padding: 0 24rpx; margin-top: 16rpx; }
.custom-amount .input { background: #fff; border-radius: 12rpx; padding: 24rpx; font-size: 32rpx; text-align: center; }
.pay-section { padding: 40rpx 24rpx; }
.pay-section .btn { width: 100%; padding: 28rpx 0; font-size: 34rpx; }
