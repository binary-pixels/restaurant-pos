.page { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 40rpx; }
.card-bg { width: 100%; max-width: 600rpx; border-radius: 32rpx; padding: 48rpx 32rpx; color: #fff; }
.card-title { font-size: 28rpx; opacity: 0.8; }
.card-body { text-align: center; margin-top: 16rpx; }
.avatar { width: 100rpx; height: 100rpx; border-radius: 50%; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; font-size: 48rpx; margin: 0 auto 12rpx; }
.name { font-size: 36rpx; font-weight: bold; }
.tier { font-size: 26rpx; opacity: 0.9; display: block; margin-top: 4rpx; }
.stats { display: flex; justify-content: center; gap: 60rpx; margin: 24rpx 0; }
.stat { text-align: center; }
.sv { font-size: 32rpx; font-weight: bold; display: block; }
.sl { font-size: 22rpx; opacity: 0.8; }
.qr-area { background: #fff; border-radius: 16rpx; padding: 20rpx; margin: 16rpx auto; display: inline-block; }
.qr-img { width: 200rpx; height: 200rpx; }
.qr-hint { color: #999; font-size: 22rpx; display: block; margin-top: 8rpx; }
.phone { font-size: 26rpx; opacity: 0.8; margin-top: 8rpx; }
