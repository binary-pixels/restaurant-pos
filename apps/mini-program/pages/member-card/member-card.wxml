<view class="page">
  <view class="card-bg" style="background: linear-gradient(135deg, {{tierColor}}, {{tierColor2}})">
    <text class="card-title">会员卡</text>
    <view class="card-body">
      <view class="avatar">👤</view>
      <text class="name">{{userName}}</text>
      <text class="tier">{{tierLabel}}</text>

      <view class="stats">
        <view class="stat"><text class="sv">{{points}}</text><text class="sl">积分</text></view>
        <view class="stat"><text class="sv">¥{{balance}}</text><text class="sl">余额</text></view>
      </view>

      <view class="qr-area">
        <image src="{{qrUrl}}" class="qr-img" mode="aspectFit" />
        <text class="qr-hint">出示给收银员扫码</text>
      </view>

      <text class="phone">{{phone}}</text>
    </view>
  </view>
</view>
