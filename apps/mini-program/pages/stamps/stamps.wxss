.page { min-height: 100vh; background: linear-gradient(135deg, #fef3c7, #fde68a); display: flex; flex-direction: column; align-items: center; padding-top: 60rpx; }
.header { text-align: center; margin-bottom: 48rpx; padding: 0 32rpx; }
.title { font-size: 44rpx; font-weight: bold; color: #92400e; }
.desc { font-size: 28rpx; color: #a16207; display: block; margin-top: 12rpx; }
.card-container { background: #fff; border-radius: 24rpx; padding: 40rpx; margin: 0 32rpx; width: calc(100% - 64rpx); text-align: center; }
.stamp-count { margin-bottom: 32rpx; }
.count-num { font-size: 72rpx; font-weight: bold; color: #d97706; }
.count-label { font-size: 28rpx; color: #999; display: block; margin-top: 4rpx; }
.stamp-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 16rpx; margin-bottom: 32rpx; }
.stamp { width: 80rpx; height: 80rpx; border-radius: 50%; background: #f3f4f6; display: flex; align-items: center; justify-content: center; font-size: 36rpx; }
.stamp.active { background: #fef3c7; }
.reward-info { margin-bottom: 24rpx; }
.reward-text { font-size: 30rpx; color: #d97706; font-weight: bold; }
