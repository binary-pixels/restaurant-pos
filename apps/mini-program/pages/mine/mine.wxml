<view class="page">
  <!-- Profile Card -->
  <view class="profile-card" bindtap="goLogin" wx:if="{{!userInfo}}">
    <view class="avatar">👤</view>
    <text class="mt-2 text-lg">登录/注册</text>
    <text class="text-sm text-gray mt-1">登录后享受会员权益</text>
  </view>

  <view class="profile-card" wx:else>
    <view class="avatar">{{userInfo.avatar || '👤'}}</view>
    <text class="mt-2 text-lg font-bold">{{userInfo.name || '会员'}}</text>
    <view class="flex mt-2" style="gap:16rpx">
      <text class="badge {{tierBadge}}">{{tierLabel}}</text>
      <text class="text-sm text-gray">{{userInfo.phone || ''}}</text>
    </view>
  </view>

  <!-- Stats -->
  <view class="stats-row" wx:if="{{userInfo}}">
    <view class="stat-item">
      <text class="stat-val">{{userInfo.points || 0}}</text>
      <text class="stat-label">积分</text>
    </view>
    <view class="stat-item">
      <text class="stat-val">¥{{balance}}</text>
      <text class="stat-label">余额</text>
    </view>
    <view class="stat-item">
      <text class="stat-val">{{userInfo.visitCount || 0}}次</text>
      <text class="stat-label">消费</text>
    </view>
  </view>

  <!-- Referral -->
  <view class="referral-card" wx:if="{{userInfo}}" bindtap="goReferral">
    <text class="ref-title">🎁 邀请好友，双方各得50积分</text>
    <text class="ref-code">我的推荐码: {{referralCode || '加载中...'}}</text>
    <text class="ref-count">已邀请 {{referralCount || 0}} 人</text>
  </view>

  <!-- Menu -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goPage" data-url="/pages/orders/orders">
      <text>📋 我的订单</text>
      <text class="text-gray">▶</text>
    </view>
    <view class="menu-item" bindtap="goPage" data-url="/pages/addresses/addresses">
      <text>📍 地址管理</text>
      <text class="text-gray">▶</text>
    </view>
    <view class="menu-item" bindtap="goPage" data-url="/pages/checkin/checkin">
      <text>📅 每日签到</text>
      <text class="text-gray">▶</text>
    </view>
    <view class="menu-item" bindtap="goPage" data-url="/pages/lucky-wheel/lucky-wheel">
      <text>🎡 幸运转盘</text>
      <text class="text-gray">▶</text>
    </view>
    <view class="menu-item" bindtap="goPage" data-url="/pages/coupons/coupons">
      <text>🎁 优惠券</text>
      <text class="text-gray">▶</text>
    </view>
    <view class="menu-item" bindtap="goPage" data-url="/pages/topup/topup">
      <text>💳 余额充值</text>
      <text class="text-gray">▶</text>
    </view>
    <view class="menu-item" bindtap="goPage" data-url="/pages/redeem/redeem">
      <text>🎫 兑换礼品卡</text>
      <text class="text-gray">▶</text>
    </view>
    <view class="menu-item" bindtap="goPage" data-url="/pages/settings/settings">
      <text>⚙️ 设置</text>
      <text class="text-gray">▶</text>
    </view>
  </view>
</view>
