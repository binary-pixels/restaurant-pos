.page { min-height: 100vh; background: #f5f5f5; }

.profile-card {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff; padding: 48rpx 32rpx; display: flex;
  flex-direction: column; align-items: center;
}
.avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: rgba(255,255,255,0.2); display: flex;
  align-items: center; justify-content: center; font-size: 50rpx;
}

.stats-row {
  display: flex; background: #fff; margin: 20rpx; border-radius: 16rpx;
  padding: 32rpx 0;
}
.stat-item {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  border-right: 1rpx solid #f0f0f0;
}
.stat-item:last-child { border-right: none; }
.stat-val { font-size: 36rpx; font-weight: bold; }
.stat-label { font-size: 24rpx; color: #999; margin-top: 4rpx; }

.menu-list { background: #fff; margin: 20rpx; border-radius: 16rpx; }
.menu-item {
  display: flex; justify-content: space-between; padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5; font-size: 30rpx;
}
.menu-item:last-child { border-bottom: none; }

.member-card-entry { background: linear-gradient(135deg, #1e1b4b, #312e81); color: #fff; margin: 20rpx; border-radius: 16rpx; padding: 24rpx; display: flex; align-items: center; justify-content: space-between; font-size: 28rpx; cursor: pointer; }

.referral-card { background: linear-gradient(135deg, #fef3c7, #fde68a); margin: 20rpx; border-radius: 16rpx; padding: 28rpx; text-align: center; cursor: pointer; }
.ref-title { font-size: 30rpx; font-weight: bold; color: #92400e; display: block; }
.ref-code { font-size: 28rpx; color: #d97706; margin-top: 8rpx; display: block; font-weight: 500; }
.ref-count { font-size: 24rpx; color: #a16207; margin-top: 4rpx; display: block; }
