.page { min-height: 100vh; background: #f5f5f5; }
.header { background: #fff; padding: 24rpx 32rpx; border-bottom: 1rpx solid #f0f0f0; }
.header-title { font-size: 34rpx; font-weight: bold; }

.address-list { padding: 20rpx; }
.address-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; }
.addr-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8rpx; }
.addr-label { font-size: 28rpx; font-weight: 500; color: #2563eb; margin-right: 12rpx; }
.addr-tag { font-size: 20rpx; background: #dcfce7; color: #16a34a; padding: 2rpx 12rpx; border-radius: 8rpx; }
.addr-actions { display: flex; gap: 20rpx; font-size: 26rpx; color: #666; }
.addr-text { font-size: 30rpx; color: #333; margin-bottom: 4rpx; }
.addr-contact { font-size: 26rpx; color: #999; }

.add-btn { margin: 20rpx; background: #fff; border-radius: 16rpx; padding: 28rpx; text-align: center; color: #2563eb; font-size: 30rpx; border: 2rpx dashed #2563eb; }

.form-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 200; display: flex; align-items: flex-end; }
.form-panel { width: 100%; background: #fff; border-radius: 32rpx 32rpx 0 0; padding: 40rpx 32rpx; padding-bottom: calc(40rpx + env(safe-area-inset-bottom)); }
.form-title { font-size: 34rpx; font-weight: bold; margin-bottom: 24rpx; display: block; }
.form-panel .input { margin-bottom: 16rpx; }
.default-check { display: flex; align-items: center; font-size: 28rpx; margin: 8rpx 0 24rpx; }
.form-btns { display: flex; gap: 20rpx; }
.form-btns .btn { flex: 1; }
