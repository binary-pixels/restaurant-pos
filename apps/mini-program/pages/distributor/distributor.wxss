.page { min-height: 100vh; background: #f5f5f5; }
.header-card { background: linear-gradient(135deg, #f59e0b, #d97706); color: #fff; padding: 48rpx 32rpx; text-align: center; }
.h-title { font-size: 36rpx; font-weight: bold; }
.h-desc { font-size: 26rpx; opacity: 0.9; display: block; margin-top: 4rpx; }
.stats { display: flex; background: #fff; margin: 20rpx; border-radius: 16rpx; padding: 24rpx 0; }
.stat { flex: 1; text-align: center; border-right: 1rpx solid #f0f0f0; }
.stat:last-child { border-right: none; }
.stat-val { font-size: 36rpx; font-weight: bold; color: #d97706; display: block; }
.stat-label { font-size: 24rpx; color: #999; }
.card { background: #fff; margin: 20rpx; border-radius: 16rpx; padding: 24rpx; }
.label { font-size: 28rpx; font-weight: 500; margin-bottom: 8rpx; display: block; }
.code { font-size: 40rpx; font-weight: bold; color: #2563eb; letter-spacing: 4rpx; display: block; text-align: center; }
.tip { font-size: 24rpx; color: #999; margin-top: 8rpx; display: block; text-align: center; }
.comm-item { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid #f5f5f5; font-size: 26rpx; }
