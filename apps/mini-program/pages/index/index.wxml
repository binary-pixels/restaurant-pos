<view class="page">
  <view class="table-bar" wx:if="{{tableLabel}}">
    <text>桌号 {{tableLabel}}</text>
  </view>

  <view class="announce-bar" wx:if="{{announcement}}">
    <text class="announce-text">📢 {{announcement.title}}: {{announcement.content}}</text>
  </view>

  <!-- First-time Guide -->
  <view class="guide-overlay" wx:if="{{showGuide}}" catchtap="dismissGuide">
    <view class="guide-card" catchtap>
      <text class="guide-title">👋 欢迎使用扫码点餐</text>
      <text class="guide-text">🖱️ 点击菜品添加到购物车</text>
      <text class="guide-text">🛒 底部查看购物车</text>
      <text class="guide-text">💳 去下单→确认支付</text>
      <view class="btn btn-primary" bindtap="dismissGuide" style="margin-top:20rpx">知道了</view>
    </view>
  </view>

  <view class="search-bar">
    <input class="search-input" placeholder="搜索菜品..." value="{{keyword}}" bindinput="onSearch" />
  </view>

  <!-- Frequent Items -->
  <view class="frequent-section" wx:if="{{frequent.length > 0 && !keyword}}">
    <text class="rec-title">🕐 常点菜品</text>
    <scroll-view class="rec-scroll" scroll-x>
      <view class="rec-item" wx:for="{{frequent}}" wx:key="id" bindtap="openSpec" data-product="{{item}}">
        <text class="rec-name">{{item.name}}</text>
        <text class="text-xs text-gray">×{{item.count}}次</text>
      </view>
      <view class="rec-item" wx:if="{{lastItems.length > 0}}" style="background:#eff6ff" bindtap="reorderLast">
        <text class="rec-name">🔄 再来一单</text>
        <text class="text-xs text-gray">{{lastItems[0].name}}等</text>
      </view>
    </scroll-view>
  </view>

  <!-- Recommended -->
  <view class="recommend-section" wx:if="{{recommended.length > 0 && !keyword}}">
    <text class="rec-title">⭐ 主厨推荐</text>
    <scroll-view class="rec-scroll" scroll-x>
      <view class="rec-item" wx:for="{{recommended}}" wx:key="id" bindtap="openSpec" data-product="{{item}}">
        <text class="rec-name">{{item.name}}</text>
        <text class="price">¥{{item.discountPrice > 0 ? item.discountPrice : item.price}}</text>
      </view>
    </scroll-view>
  </view>

  <scroll-view class="cat-tabs" scroll-x>
    <view class="cat-tab {{activeCat === 'all' ? 'active' : ''}}" bindtap="switchCat" data-id="all">全部</view>
    <view class="cat-tab {{activeCat === item.id ? 'active' : ''}}" wx:for="{{categories}}" wx:key="id" bindtap="switchCat" data-id="{{item.id}}">{{item.name}}</view>
  </scroll-view>

  <!-- Skeleton Loading -->
  <view class="skeleton-list" wx:if="{{loading}}">
    <view class="sk-card" wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this">
      <view class="sk-img shimmer"></view>
      <view class="sk-info">
        <view class="sk-line shimmer w80"></view>
        <view class="sk-line shimmer w50"></view>
      </view>
    </view>
  </view>

  <scroll-view class="product-list" scroll-y>
    <view class="product-card" wx:for="{{filteredProducts}}" wx:key="id" bindtap="openSpec" data-product="{{item}}">
      <view class="product-img"><text class="product-img-text">{{item.name[0]}}</text></view>
      <view class="product-info">
        <text class="product-name">{{item.name}}</text>
        <view class="product-row">
          <text wx:if="{{item.discountPrice > 0 && item.stock > 0}}" style="text-decoration:line-through;color:#999;font-size:24rpx;margin-right:8rpx">¥{{item.price}}</text>
          <text class="price" wx:if="{{item.stock > 0}}">¥{{item.discountPrice > 0 ? item.discountPrice : item.price}}</text>
          <text class="price" wx:else style="color:#999">售罄</text>
          <view class="qty-ctrl" wx:if="{{item.stock > 0}}">
            <view class="qty-btn" catchtap="decQty" data-id="{{item.id}}">-</view>
            <text class="qty-num">{{item._qty || 0}}</text>
            <view class="qty-btn add" catchtap="incQty" data-id="{{item.id}}">+</view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- Back to Top -->
  <view class="back-top {{showBackTop ? 'visible' : ''}}" bindtap="scrollToTop" wx:if="{{showBackTop}}">
    <text>⬆</text>
  </view>

  <view class="cart-bar" wx:if="{{cartCount > 0}}" bindtap="goOrder">
    <view class="cart-left">
      <view class="cart-icon">🛒<text class="cart-badge">{{cartCount}}</text></view>
      <text style="color:#fff;font-size:32rpx;font-weight:bold">¥{{cartTotal}}</text>
    </view>
    <view class="cart-btn">去下单</view>
  </view>
</view>

<spec-popup product="{{specProduct}}" show="{{showSpec}}" bind:confirm="onSpecConfirm" bind:close="onSpecClose" />
