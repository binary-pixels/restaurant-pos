.page { display: flex; flex-direction: column; height: 100vh; background: #f5f5f5; }

.table-bar { background: #2563eb; color: #fff; padding: 16rpx 32rpx; font-size: 26rpx; }

.announce-bar { background: #fef3c7; padding: 12rpx 24rpx; }
.announce-text { font-size: 24rpx; color: #92400e; }

.recommend-section { background: #fff; padding: 8rpx 24rpx 16rpx; }
.rec-title { font-size: 26rpx; font-weight: bold; color: #f59e0b; margin-bottom: 8rpx; display: block; }
.rec-scroll { white-space: nowrap; }
.rec-item { display: inline-block; background: #fef3c7; border-radius: 12rpx; padding: 12rpx 24rpx; margin-right: 12rpx; text-align: center; }
.rec-name { font-size: 26rpx; font-weight: 500; color: #92400e; display: block; }

.search-bar { padding: 16rpx 24rpx; background: #fff; }
.search-input { background: #f5f5f5; height: 68rpx; border-radius: 34rpx; padding: 0 32rpx; font-size: 26rpx; }

.cat-tabs { white-space: nowrap; background: #fff; padding: 16rpx 24rpx; border-bottom: 1rpx solid #f0f0f0; }
.cat-tab { display: inline-block; padding: 10rpx 28rpx; margin-right: 12rpx; border-radius: 8rpx; font-size: 26rpx; background: #f5f5f5; color: #666; }
.cat-tab.active { background: #2563eb; color: #fff; }

.product-list { height: calc(100vh - 200rpx); }

.product-card { display: flex; background: #fff; border-radius: 16rpx; padding: 24rpx; margin: 0 20rpx 16rpx 20rpx; }
.product-img { width: 140rpx; height: 140rpx; background: #f0f5ff; border-radius: 12rpx; display: flex; align-items: center; justify-content: center; margin-right: 20rpx; flex-shrink: 0; }
.product-img-text { font-size: 48rpx; color: #2563eb; font-weight: bold; }
.product-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
.product-name { font-size: 30rpx; font-weight: 500; }
.product-row { display: flex; align-items: center; justify-content: space-between; margin-top: 8rpx; }

.qty-ctrl { display: flex; align-items: center; }
.qty-btn { width: 44rpx; height: 44rpx; border-radius: 50%; border: 2rpx solid #ddd; display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: #666; margin: 0 6rpx; }
.qty-btn { width: 44rpx; height: 44rpx; border-radius: 50%; border: 2rpx solid #ddd; display: flex; align-items: center; justify-content: center; font-size: 32rpx; color: #666; margin: 0 12rpx; }
.qty-btn.add { background: #2563eb; color: #fff; border-color: #2563eb; }
.qty-num { font-size: 28rpx; min-width: 40rpx; text-align: center; }

.cart-bar { position: fixed; bottom: 0; left: 0; right: 0; height: 100rpx; background: #1f2937; display: flex; align-items: center; justify-content: space-between; padding: 0 32rpx; z-index: 100; }
.cart-left { display: flex; align-items: center; }
.cart-icon { position: relative; font-size: 40rpx; margin-right: 16rpx; }
.cart-badge { position: absolute; top: -12rpx; right: -16rpx; background: #ef4444; color: #fff; min-width: 32rpx; height: 32rpx; border-radius: 16rpx; font-size: 20rpx; display: flex; align-items: center; justify-content: center; padding: 0 6rpx; }
.cart-btn { background: #2563eb; color: #fff; padding: 16rpx 48rpx; border-radius: 12rpx; font-size: 30rpx; font-weight: 500; }
